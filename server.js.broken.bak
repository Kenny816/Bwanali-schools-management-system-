// ---------- AUTO INVOICE FROM PROCESSING FEE ----------
app.post('/api/invoices/generate-processing-fee', authMiddleware, async (req, res) => {
  const { student_id } = req.body;
  if (!student_id) return res.status(400).json({ error: "student_id required" });
  const { data: student, error: studErr } = await supabase.from('students')
    .select('processing_fee, first_name, last_name, admission_no')
    .eq('id', student_id).eq('tenant_id', req.tenant.id).single();
  if (studErr || !student) return res.status(404).json({ error: "Student not found" });
  const fee = student.processing_fee;
  if (!fee || !fee.amount || fee.amount <= 0) return res.status(400).json({ error: "No processing fee defined" });
  const invNo = 'INV-'+Date.now()+'-'+Math.random().toString(36).substr(2,3);
  const invData = {
    tenant_id: req.tenant.id,
    student_id,
    invoice_number: invNo,
    issue_date: new Date().toISOString().split('T')[0],
    due_date: new Date(Date.now()+30*24*60*60*1000).toISOString().split('T')[0],
    total_amount: fee.amount,
    status: fee.paid ? 'Paid' : 'Unpaid'
  };
  const { data: invoice, error: invErr } = await supabase.from('invoices').insert(invData).select('*').single();
  if (invErr) {
    console.error("Invoice creation error:", invErr);
    return res.status(400).json({ error: "Could not create invoice" });
  }
  res.status(201).json(invoice);
// ---------- IMPROVED PAYMENT (with invoice linking) ----------
app.post('/api/payments', authMiddleware, async (req, res) => {
  const { student_id, amount, payment_method, remarks, invoice_id } = req.body;
  if (!student_id || !amount) return res.status(400).json({ error: "Student and amount required." });
  const receipt = "RCP" + Date.now();
  const paymentData = {
    tenant_id: req.tenant.id,
    student_id,
    amount,
    payment_method: payment_method || "Cash",
    remarks: remarks || "",
    receipt_number: receipt,
    invoice_id: invoice_id || null
  };
  const { data: payment, error } = await supabase.from('payments').insert(paymentData).select('*').single();
  if (error) {
    console.error("Payment insert error:", error);
    return res.status(400).json({ error: "Could not record payment. " + (error.message || "") });
  }
  // If an invoice_id was provided, mark it as Paid
  if (invoice_id) {
    const { error: updateErr } = await supabase.from('invoices').update({ status: 'Paid' }).eq('id', invoice_id).eq('tenant_id', req.tenant.id);
    if (updateErr) console.error("Invoice update error:", updateErr);
  }
  res.status(201).json(payment);
