app.get('/api/students/:id/outstanding', authMiddleware, async (req, res) => {
  const { data: invoices } = await supabase.from('invoices')
    .select('total_amount, status')
    .eq('student_id', req.params.id)
    .eq('tenant_id', req.tenant.id);
  const unpaid = (invoices || []).filter(inv => inv.status !== 'Paid');
  const totalOutstanding = unpaid.reduce((s, inv) => s + parseFloat(inv.total_amount), 0);
  res.json({ outstanding: totalOutstanding, unpaid_count: unpaid.length });
// ---------- CREATE INVOICE WITH ITEMS AND PAY ----------
app.post('/api/invoices/generate-with-items', authMiddleware, async (req, res) => {
  const { student_id, items, payment_method, remarks } = req.body;
  if (!student_id || !items || !items.length) return res.status(400).json({ error: "Student and at least one fee item required." });
  const total_amount = items.reduce((s, i) => s + parseFloat(i.amount), 0);
  const invNo = 'INV-'+Date.now()+'-'+Math.random().toString(36).substr(2,3);
  const invData = {
    tenant_id: req.tenant.id,
    student_id,
    invoice_number: invNo,
    issue_date: new Date().toISOString().split('T')[0],
    due_date: new Date(Date.now()+30*24*60*60*1000).toISOString().split('T')[0],
    total_amount,
    status: 'Paid'
  };
  const { data: invoice, error: invErr } = await supabase.from('invoices').insert(invData).select('*').single();
  if (invErr) return res.status(400).json({ error: "Could not create invoice: " + invErr.message });
  const itemRecords = items.map(item => ({
    invoice_id: invoice.id,
    fee_type_id: item.fee_type_id || null,
    description: item.description || 'Fee',
    amount: parseFloat(item.amount)
  }));
  const { error: itemsErr } = await supabase.from('invoice_items').insert(itemRecords);
  if (itemsErr) {
    console.error("Invoice items insert error:", itemsErr);
    return res.status(400).json({ error: "Could not save invoice items." });
  }
  // Record payment automatically
  const receipt = "RCP" + Date.now();
  const { data: payment, error: payErr } = await supabase.from('payments').insert({
    tenant_id: req.tenant.id,
    student_id,
    invoice_id: invoice.id,
    amount: total_amount,
    payment_method: payment_method || 'Cash',
    remarks: remarks || 'Payment for selected fees',
    receipt_number: receipt
  }).select('*').single();
  if (payErr) {
    console.error("Payment insert error:", payErr);
    return res.status(400).json({ error: "Could not record payment." });
  }
  res.status(201).json({ invoice, payment });
// ---------- PROFILE PICTURE UPLOAD ----------
app.put('/api/enrollments/:id/profile-picture', authMiddleware, async (req, res) => {
  try {
    const { data, error } = await supabase
      .from('students')
      .update({
        profile_picture: req.body.profile_picture || '',
        first_name: req.body.first_name,
        last_name: req.body.last_name,
        phone: req.body.phone,
        email: req.body.email
      })
      .eq('id', req.params.id)
      .eq('tenant_id', req.tenant.id)
      .select('*')
      .single();

    if (error) {
      console.error('Profile picture update error:', error);
      return res.status(400).json({ error: error.message });
    }
    res.json(data);
  } catch (err) {
    console.error('Profile picture endpoint error:', err);
    res.status(500).json({ error: 'Internal server error' });
  }

