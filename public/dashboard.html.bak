<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1.0">
  <title>Dashboard – Bwanali</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body data-page="dashboard">
<script src="/shared.js"></script>

<!-- ==================== DASHBOARD MODULES ==================== -->
<!-- Dashboard Home -->
<div id="module-dashboard" class="module-content active">
  <div class="stats-grid">
    <div class="stat-card"><span class="stat-label">Students</span><span class="stat-value" id="statStudents">-</span></div>
    <div class="stat-card"><span class="stat-label">Staff</span><span class="stat-value" id="statStaff">-</span></div>
    <div class="stat-card"><span class="stat-label">Attendance</span><span class="stat-value" id="statAttendance">-</span></div>
    <div class="stat-card"><span class="stat-label">Fees Collected</span><span class="stat-value" id="statFees">-</span></div>
  </div>
</div>

<!-- Enrollment Module -->
<div id="module-enrollment" class="module-content">
  <div class="module-header"><h2>Enrollment Management</h2><button class="btn-primary" id="addStudentBtn">+ Add Student</button></div>
  <!-- Enrollment Form Modal -->
  <div class="modal" id="enrollmentModal"><div class="modal-overlay"></div><div class="modal-content"><span class="modal-close" id="closeModalBtn">&times;</span><h3 id="modalTitle">Add New Student</h3>
    <form id="enrollmentForm"><input type="hidden" id="studentId">
      <fieldset><legend>Personal Information</legend><div class="form-row"><div class="form-group"><label>Admission No</label><input type="text" id="admissionNo" readonly placeholder="Auto-generated" class="readonly-input"></div><div class="form-group"><label>Enrollment Date</label><input type="date" id="enrollmentDate"></div></div><div class="form-row"><div class="form-group"><label>First Name *</label><input type="text" id="firstName" required></div><div class="form-group"><label>Last Name *</label><input type="text" id="lastName" required></div></div><div class="form-row"><div class="form-group"><label>Date of Birth</label><input type="date" id="dob"></div><div class="form-group"><label>Gender</label><select id="gender"><option value="Male">Male</option><option value="Female">Female</option></select></div></div></fieldset>
      <fieldset><legend>Class Assignment</legend><div class="form-row"><div class="form-group"><label>Class *</label><input type="text" id="className" required></div><div class="form-group"><label>Section</label><input type="text" id="section"></div></div></fieldset>
      <fieldset><legend>Parent / Guardian</legend><div class="form-row"><div class="form-group"><label>Parent/Guardian Name</label><input type="text" id="parentName"></div><div class="form-group"><label>Phone</label><input type="text" id="phone"></div></div><div class="form-row"><div class="form-group"><label>Email</label><input type="email" id="email"></div><div class="form-group"><label>Address</label><input type="text" id="address"></div></div></fieldset>
      <fieldset><legend>Previous Education (Optional)</legend><div id="previousSchoolsContainer"><div class="previous-school-row"><div class="form-group"><label>School 1 Name</label><input type="text" class="prev-school-name" placeholder="e.g., Riverside Primary"></div><div class="form-group"><label>Year(s) Attended</label><input type="text" class="prev-school-year" placeholder="e.g., 2015-2018"></div></div><div class="previous-school-row"><div class="form-group"><label>School 2 Name</label><input type="text" class="prev-school-name"></div><div class="form-group"><label>Year(s) Attended</label><input type="text" class="prev-school-year"></div></div><div class="previous-school-row"><div class="form-group"><label>School 3 Name</label><input type="text" class="prev-school-name"></div><div class="form-group"><label>Year(s) Attended</label><input type="text" class="prev-school-year"></div></div></div></fieldset>
      <fieldset><legend>Placement Assessment (Optional)</legend><div class="form-row"><div class="form-group"><label class="checkbox-label"><input type="checkbox" id="assessmentCheckbox"> Schedule an assessment</label></div></div><div id="assessmentDetails" style="display:none;"><div class="form-row"><div class="form-group"><label>Assessment Date</label><input type="date" id="assessmentDate"></div><div class="form-group"><label>Subject / Focus</label><input type="text" id="assessmentSubject" placeholder="e.g., Mathematics"></div></div></div></fieldset>
      <div class="form-actions"><button type="button" class="btn-secondary" id="cancelBtn">Cancel</button><button type="submit" class="btn-primary">Save</button></div>
    </form>
  </div></div>
  <!-- Processing Fee Modal -->
  <div class="modal" id="feeModal"><div class="modal-overlay"></div><div class="modal-content" style="max-width:400px;"><h3>Processing Fee</h3><p>This school requires a processing fee for enrollment.</p>
    <form id="feeForm"><div class="form-group"><label>Amount *</label><input type="number" id="feeAmount" placeholder="Enter amount" required></div><div class="form-group"><label>Payment Method</label><select id="feeMethod"><option value="Cash">Cash</option><option value="Bank Transfer">Bank Transfer</option><option value="Mobile Money">Mobile Money</option><option value="Cheque">Cheque</option></select></div><div class="form-group"><label class="checkbox-label"><input type="checkbox" id="feePaid"> Mark as Paid</label></div><div class="form-actions"><button type="button" class="btn-secondary" id="feeSkipBtn">Skip</button><button type="submit" class="btn-primary">Confirm & Save</button></div></form>
  </div></div>
  <div class="table-container"><table class="data-table" id="studentsTable"><thead><tr><th>Adm No</th><th>Name</th><th>Class</th><th>Section</th><th>Parent</th><th>Phone</th><th>Assessment</th><th>Fee</th><th>Actions</th></tr></thead><tbody></tbody></table></div>
</div>

<!-- Classes Module -->
<div id="module-classes" class="module-content">
  <div class="module-header"><h2>Classes & Sections</h2><button class="btn-primary" id="addClassBtn">+ Add Class</button></div>
  <div class="modal" id="classModal"><div class="modal-overlay"></div><div class="modal-content"><span class="modal-close" id="closeClassModalBtn">&times;</span><h3 id="classModalTitle">Add New Class</h3>
    <form id="classForm"><input type="hidden" id="classId">
      <div class="form-row"><div class="form-group"><label>Name *</label><input type="text" id="classNameInput" required></div><div class="form-group"><label>Numeric Order</label><input type="number" id="numericOrder"></div></div>
      <div class="form-row"><div class="form-group"><label>Section</label><input type="text" id="sectionInput"></div><div class="form-group"><label>Capacity</label><input type="number" id="capacityInput" value="40"></div></div>
      <div class="form-row"><div class="form-group"><label>Class Teacher</label><input type="text" id="classTeacher"></div></div>
      <div class="form-actions"><button type="button" class="btn-secondary" id="cancelClassBtn">Cancel</button><button type="submit" class="btn-primary">Save</button></div>
    </form>
  </div></div>
  <div class="modal" id="classStudentsModal"><div class="modal-overlay"></div><div class="modal-content"><span class="modal-close" id="closeClassStudentsBtn">&times;</span><h3 id="classStudentsTitle">Students</h3><p>Teacher: <span id="classTeacherName"></span></p><div class="table-container"><table class="data-table" id="classStudentsTable"><thead><tr><th>Adm No</th><th>Name</th><th>Parent</th><th>Phone</th></tr></thead><tbody></tbody></table></div></div></div>
  <div class="table-container"><table class="data-table" id="classesTable"><thead><tr><th>Name</th><th>Order</th><th>Section</th><th>Capacity</th><th>Teacher</th><th>Actions</th></tr></thead><tbody></tbody></table></div>
</div>

<!-- Staff Module -->
<div id="module-staffing" class="module-content">
  <div class="module-header"><h2>Staff Management</h2><button class="btn-primary" id="addStaffBtn">+ Add Staff</button></div>
  <div class="modal" id="staffModal"><div class="modal-overlay"></div><div class="modal-content"><span class="modal-close" id="closeStaffModalBtn">&times;</span><h3 id="staffModalTitle">Add Staff</h3>
    <form id="staffForm"><input type="hidden" id="staffId">
      <div class="form-row"><div class="form-group"><label>First Name *</label><input type="text" id="staffFirstName" required></div><div class="form-group"><label>Last Name *</label><input type="text" id="staffLastName" required></div></div>
      <div class="form-row"><div class="form-group"><label>Role</label><select id="staffRole"><option value="Teacher">Teacher</option><option value="HOD">HOD</option><option value="Deputy">Deputy</option><option value="Accountant">Accountant</option><option value="Guidance">Guidance</option><option value="Other">Other</option></select></div><div class="form-group"><label>Department</label><input type="text" id="staffDepartment"></div></div>
      <div class="form-row"><div class="form-group"><label>Phone</label><input type="text" id="staffPhone"></div><div class="form-group"><label>Email</label><input type="email" id="staffEmail"></div></div>
      <div class="form-row"><div class="form-group"><label>Joining Date</label><input type="date" id="staffJoiningDate"></div></div>
      <div class="form-actions"><button type="button" class="btn-secondary" id="cancelStaffBtn">Cancel</button><button type="submit" class="btn-primary">Save</button></div>
    </form>
  </div></div>
  <div class="table-container"><table class="data-table" id="staffTable"><thead><tr><th>Name</th><th>Role</th><th>Department</th><th>Phone</th><th>Email</th><th>Joining Date</th><th>Actions</th></tr></thead><tbody></tbody></table></div>
</div>

<!-- Committees Module -->
<div id="module-committees" class="module-content">
  <div class="module-header"><h2>Committees</h2><button class="btn-primary" id="addCommitteeBtn">+ Add Committee</button></div>
  <div class="modal" id="committeeModal"><div class="modal-overlay"></div><div class="modal-content"><span class="modal-close" id="closeCommitteeModalBtn">&times;</span><h3 id="committeeModalTitle">Add Committee</h3>
    <form id="committeeForm"><input type="hidden" id="committeeId">
      <div class="form-row"><div class="form-group"><label>Name *</label><input type="text" id="committeeName" required></div><div class="form-group"><label>Description</label><input type="text" id="committeeDescription"></div></div>
      <div class="form-actions"><button type="button" class="btn-secondary" id="cancelCommitteeBtn">Cancel</button><button type="submit" class="btn-primary">Save</button></div>
    </form>
  </div></div>
  <div class="modal" id="membersModal"><div class="modal-overlay"></div><div class="modal-content"><span class="modal-close" id="closeMembersModalBtn">&times;</span><h3>Manage Members</h3><div id="membersList"></div><div class="form-row"><div class="form-group"><label>Add Member</label><input type="text" id="newMemberName" placeholder="Name"></div></div><button class="btn-primary" id="addMemberBtn">Add</button><button class="btn-secondary" id="closeMembersBtn">Close</button></div></div>
  <div class="table-container"><table class="data-table" id="committeesTable"><thead><tr><th>Name</th><th>Description</th><th>Chairperson</th><th>Members</th><th>Actions</th></tr></thead><tbody></tbody></table></div>
</div>

<!-- Monitoring Module -->
<div id="module-monitoring" class="module-content">
  <h2>School Monitoring</h2>
  <div class="monitoring-grid" id="monitoringCards"></div>
  <div class="monitoring-table"><h3>Class-wise Enrollment</h3><table id="classEnrollmentTable"><thead><tr><th>Class</th><th>Students</th></tr></thead><tbody></tbody></table></div>
  <div class="monitoring-table" style="margin-top:30px;"><h3>Recent Enrollments</h3><table id="recentEnrollmentsTable"><thead><tr><th>Adm No</th><th>Name</th><th>Date</th></tr></thead><tbody></tbody></table></div>
</div>

<!-- Teacher Monitoring -->
<div id="module-teacher-monitoring" class="module-content">
  <h2>Teacher Monitoring</h2>
  <div class="monitoring-grid" id="teacherStatsCards"></div>
  <div id="teacherList"></div>
</div>

<!-- Attendance Module -->
<div id="module-attendance" class="module-content">
  <h2>Pupils Attendance</h2>
  <div class="attendance-controls"><input type="date" id="attendanceDate"><select id="classFilter"><option value="">All Classes</option></select><button class="btn-primary" id="loadAttendanceBtn">Load</button></div>
  <div class="table-container"><table class="data-table" id="attendanceTable"><thead><tr><th>Adm No</th><th>Name</th><th>Class</th><th>Section</th><th>Status</th><th>Remarks</th></tr></thead><tbody></tbody></table></div>
  <div class="form-actions" style="margin-top:20px;"><button class="btn-primary" id="saveAttendanceBtn">Save Attendance</button></div>
</div>

<!-- Assessments Module -->
<div id="module-assessments" class="module-content">
  <div class="module-header"><h2>Assessments</h2><button class="btn-primary" id="addAssessmentBtn">+ Add Assessment</button></div>
  <div class="modal" id="assessmentModal"><div class="modal-overlay"></div><div class="modal-content"><span class="modal-close" id="closeAssessmentModalBtn">&times;</span><h3 id="assessmentModalTitle">Add Assessment</h3>
    <form id="assessmentForm"><input type="hidden" id="assessmentId">
      <div class="form-row"><div class="form-group"><label>Name *</label><input type="text" id="assessmentName" required></div><div class="form-group"><label>Type</label><select id="assessmentType"><option value="Exam">Exam</option><option value="Test">Test</option><option value="Quiz">Quiz</option><option value="Assignment">Assignment</option></select></div></div>
      <div class="form-row"><div class="form-group"><label>Date</label><input type="date" id="assessmentDateInput"></div><div class="form-group"><label>Subject</label><input type="text" id="assessmentSubjectInput"></div></div>
      <div class="form-row"><div class="form-group"><label>Class</label><select id="assessmentClass"><option value="">Select class</option></select></div><div class="form-group"><label>Max Score</label><input type="number" id="assessmentMaxScore" value="100"></div></div>
      <div class="form-actions"><button type="button" class="btn-secondary" id="cancelAssessmentBtn">Cancel</button><button type="submit" class="btn-primary">Save</button></div>
    </form>
  </div></div>
  <div class="modal" id="marksModal"><div class="modal-overlay"></div><div class="modal-content"><span class="modal-close" id="closeMarksModalBtn">&times;</span><h3 id="marksModalTitle">Enter Marks</h3><div class="table-container"><table class="data-table" id="marksTable"><thead><tr><th>Adm No</th><th>Name</th><th>Score</th><th>Remarks</th></tr></thead><tbody></tbody></table></div><div class="form-actions"><button class="btn-primary" id="saveMarksBtn">Save Marks</button></div></div></div>
  <div class="table-container"><table class="data-table" id="assessmentsTable"><thead><tr><th>Name</th><th>Type</th><th>Date</th><th>Subject</th><th>Class</th><th>Max Score</th><th>Actions</th></tr></thead><tbody></tbody></table></div>
</div>

<!-- Results Module -->
<div id="module-results" class="module-content">
  <h2>Results</h2>
  <div class="results-controls"><select id="resultsClassFilter"><option value="">Select Class</option></select><button class="btn-primary" id="loadResultsBtn">Load Results</button></div>
  <div class="table-container"><table class="data-table" id="resultsTable"><thead><tr><th>Adm No</th><th>Name</th><th>Total Score</th><th>Average (%)</th><th>Details</th></tr></thead><tbody></tbody></table></div>
  <div class="modal" id="studentMarksModal"><div class="modal-overlay"></div><div class="modal-content"><span class="modal-close" id="closeStudentMarksBtn">&times;</span><h3 id="studentMarksTitle">Student Marks</h3><div class="table-container"><table class="data-table" id="studentMarksTable"><thead><tr><th>Assessment</th><th>Type</th><th>Subject</th><th>Score</th><th>Max</th><th>Remarks</th></tr></thead><tbody></tbody></table></div></div></div>
</div>

<!-- Accounts Module -->
<div id="module-accounts" class="module-content">
  <h2>Accounts & Finance</h2>
  <div class="monitoring-grid" id="financeSummaryCards"></div>
  <div class="tab-nav">
    <button class="tab-btn active" data-tab="invoicesTab">Invoices</button>
    <button class="tab-btn" data-tab="feeTypesTab">Fee Types</button>
    <button class="tab-btn" data-tab="paymentsTab">Record Payment</button>
  </div>
  <div id="invoicesTab" class="tab-content active">
    <div class="module-header"><h3>Invoices</h3><button class="btn-primary" id="generateInvoiceBtn">+ Generate Invoice</button></div>
    <div class="table-container"><table class="data-table" id="invoicesTable"><thead><tr><th>Invoice No</th><th>Student</th><th>Issue Date</th><th>Due Date</th><th>Amount</th><th>Status</th><th>Actions</th></tr></thead><tbody></tbody></table></div>
  </div>
  <div id="feeTypesTab" class="tab-content">
    <div class="module-header"><h3>Fee Types</h3><button class="btn-primary" id="addFeeTypeBtn">+ Add Fee Type</button></div>
    <div class="table-container"><table class="data-table" id="feeTypesTable"><thead><tr><th>Name</th><th>Description</th><th>Default Amount</th><th>Actions</th></tr></thead><tbody></tbody></table></div>
  </div>
  <div id="paymentsTab" class="tab-content">
    <h3>Record Payment</h3>
    <div class="form-row">
      <div class="form-group"><label>Select Invoice</label><select id="paymentInvoiceSelect"><option value="">-- Select --</option></select></div>
      <div class="form-group"><label>Amount</label><input type="number" id="paymentAmount"></div>
      <div class="form-group"><label>Method</label><select id="paymentMethod"><option>Cash</option><option>Bank Transfer</option><option>Mobile Money</option></select></div>
      <div class="form-group"><label>Remarks</label><input type="text" id="paymentRemarks"></div>
    </div>
    <button class="btn-primary" id="recordPaymentBtn">Record Payment</button>
  </div>
  <!-- Modals: Generate Invoice, Invoice Detail, Receipt (simplified) -->
  <div class="modal" id="generateInvoiceModal"><div class="modal-overlay"></div><div class="modal-content"><span class="modal-close" id="closeGenerateInvoiceBtn">&times;</span><h3>Generate Invoice</h3>
    <form id="generateInvoiceForm">
      <div class="form-group"><label>Student</label><select id="invoiceStudent"><option value="">Select Student</option></select></div>
      <div id="feeTypeCheckboxes"></div>
      <div class="form-group"><label>Due Date</label><input type="date" id="invoiceDueDate"></div>
      <div class="form-actions"><button type="button" class="btn-secondary" id="cancelGenerateInvoice">Cancel</button><button type="submit" class="btn-primary">Generate</button></div>
    </form>
  </div></div>
  <div class="modal" id="invoiceDetailModal"><div class="modal-overlay"></div><div class="modal-content"><span class="modal-close" id="closeInvoiceDetailBtn">&times;</span><h3>Invoice Details</h3><div id="invoiceDetailContent"></div></div></div>
  <div class="modal" id="receiptModal"><div class="modal-overlay"></div><div class="modal-content"><span class="modal-close" id="closeReceiptBtn">&times;</span><h3>Payment Receipt</h3><div id="receiptContent"></div></div></div>
</div>

<!-- Notifications Module -->
<div id="module-notifications" class="module-content">
  <div class="module-header"><h2>Notifications</h2><button class="btn-primary" id="addNotificationBtn">+ New Notification</button></div>
  <div class="modal" id="notificationModal"><div class="modal-overlay"></div><div class="modal-content" style="max-width:600px;"><span class="modal-close" id="closeNotificationModalBtn">&times;</span><h3 id="notificationModalTitle">Add Notification</h3>
    <form id="notificationForm"><input type="hidden" id="notificationId">
      <div class="form-row"><div class="form-group"><label>Title *</label><input type="text" id="notificationTitle" required></div><div class="form-group"><label>Type</label><select id="notificationType"><option value="General">General</option><option value="Announcement">Announcement</option><option value="Alert">Alert</option></select></div></div>
      <div class="form-row"><div class="form-group"><label>Priority</label><select id="notificationPriority"><option value="High">High</option><option value="Medium" selected>Medium</option><option value="Low">Low</option></select></div><div class="form-group"><label>Labels (comma separated)</label><input type="text" id="notificationLabels" placeholder="e.g., academic,urgent"></div></div>
      <div class="form-row"><div class="form-group"><label>Message</label><textarea id="notificationMessage" rows="3" style="width:100%;padding:10px;"></textarea></div></div>
      <div class="form-row"><div class="form-group"><label>Target Audience</label><input type="text" id="notificationAudience" placeholder="All, Teachers, Class:Grade 1"></div></div>
      <div class="form-actions"><button type="button" class="btn-secondary" id="cancelNotificationBtn">Cancel</button><button type="submit" class="btn-primary">Save</button></div>
    </form>
  </div></div>
  <div class="table-container"><table class="data-table" id="notificationsTable"><thead><tr><th>Title</th><th>Type</th><th>Priority</th><th>Labels</th><th>Message</th><th>Audience</th><th>Date</th><th>Actions</th></tr></thead><tbody></tbody></table></div>
</div>

<!-- ==================== JAVASCRIPT ==================== -->
<script>
const _token = sessionStorage.getItem('bwanali_token');  alert('Session expired. Please log in again.');  window.location.href = '/login.html';}
const params = new URLSearchParams(window.location.search);
const tenant = params.get('tenant') || 'demo';
let allClasses = [], students = [], classes = [], staff = [], committees = [], assessments = [], feeTypes = [], invoices = [];
let tenantInfo = {}, pendingStudentData = null, currentCommitteeId = null, currentMarksAssessmentId = null;

async function loadTenantInfo() {
  try {
    const res = await fetch(`/api/tenant?tenant=${tenant}`);
    if (!res.ok) { alert('Tenant not found!'); return; }
    tenantInfo = await res.json();
  } catch(e) { alert('Network error'); }
}

function switchModule(moduleId) {
  document.querySelectorAll('.module-content').forEach(d => d.classList.remove('active'));
  document.querySelectorAll('.nav-item[data-module]').forEach(i => i.classList.remove('active'));
  const target = document.getElementById('module-' + moduleId);
  if (target) target.classList.add('active');
  const nav = document.querySelector(`.nav-item[data-module="${moduleId}"]`);
  if (nav) nav.classList.add('active');
  document.getElementById('schoolTitle').innerText = tenant + ' - ' + moduleId.replace(/-/g, ' ').replace(/\b\w/g, l => l.toUpperCase());
  if (moduleId === 'dashboard') loadDashboardStats();
  if (moduleId === 'enrollment') loadStudents();
  if (moduleId === 'classes') loadClasses();
  if (moduleId === 'staffing') loadStaff();
  if (moduleId === 'committees') loadCommittees();
  if (moduleId === 'monitoring') loadMonitoringData();
  if (moduleId === 'teacher-monitoring') loadTeacherMonitoring();
  if (moduleId === 'attendance') initAttendancePage();
  if (moduleId === 'assessments') initAssessmentsPage();
  if (moduleId === 'results') initResultsPage();
  if (moduleId === 'accounts') initAccountsPage();
  if (moduleId === 'notifications') loadNotifications();
}

async function loadDashboardStats() {
  const res = await fetch(`/api/dashboard?tenant=${tenant}`);
  const data = await res.json();
  document.getElementById('statStudents').innerText = data.stats.students;
  document.getElementById('statStaff').innerText = data.stats.staff;
  document.getElementById('statAttendance').innerText = data.stats.attendance;
  document.getElementById('statFees').innerText = data.stats.feesCollected;
}

// ========== ENROLLMENT (with session‑expiry redirect) ==========
async function saveStudent(e) {
  e.preventDefault();
  const id = document.getElementById('studentId').value;
  const studentData = getEnrollmentFormData();
  if (!id && tenantInfo.type === 'private') {
    pendingStudentData = studentData;
    showFeeModal();
    return;
  }
  const student = await submitEnrollment(studentData, id);
  if (student && !id) {
    if (tenantInfo.type !== 'private') {
      window.location.href = `/pages/student.html?tenant=${tenant}&id=${student.id}`;
    } else {
      window.location.href = `/pages/pay-fees.html?tenant=${tenant}&studentId=${student.id}`;
    }
  }
}

async function submitEnrollment(studentData, id = null, processingFee = null) {
  if (processingFee) studentData.processingFee = processingFee;
  const url = id ? `/api/enrollments/${id}?tenant=${tenant}` : `/api/enrollments?tenant=${tenant}`;
  const method = id ? 'PUT' : 'POST';
  const res = await fetch(url, { method, headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(studentData) });
  if (res.ok) {
    const newStudent = await res.json();
    hideStudentModal(); hideFeeModal();
    pendingStudentData = null;
    return newStudent;
  } else {
    const err = await res.json();
    if (res.status === 401) {
      alert('Your session has expired. Please log in again.');
      window.location.href = '/login.html';
      return null;
    }
    alert('Error: ' + (err.error || 'Could not save'));
    return null;
  }
}

function editStudent(id) { const s = students.find(s => s.id === id); if (s) showStudentModal('Edit Student', s); }
async function deleteStudent(id) { if (!confirm('Delete?')) return; await fetch(`/api/enrollments/${id}?tenant=${tenant}`, { method: 'DELETE' }); loadStudents(); loadDashboardStats(); }

document.getElementById('feeForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const fee = { amount: parseFloat(document.getElementById('feeAmount').value), method: document.getElementById('feeMethod').value, paid: document.getElementById('feePaid').checked, date: new Date().toISOString().split('T')[0] };
  const student = await submitEnrollment(pendingStudentData, document.getElementById('studentId').value, fee);
  if (student) window.location.href = `/pages/pay-fees.html?tenant=${tenant}&studentId=${student.id}`;
});
document.getElementById('feeSkipBtn').addEventListener('click', async () => {
  const student = await submitEnrollment(pendingStudentData, document.getElementById('studentId').value, null);
  if (student) window.location.href = `/pages/pay-fees.html?tenant=${tenant}&studentId=${student.id}`;
});
document.getElementById('addStudentBtn').addEventListener('click', () => showStudentModal('Add New Student'));
document.getElementById('closeModalBtn').addEventListener('click', hideStudentModal);
document.getElementById('cancelBtn').addEventListener('click', hideStudentModal);
document.getElementById('enrollmentForm').addEventListener('submit', saveStudent);
document.getElementById('assessmentCheckbox').addEventListener('change', () => {
  document.getElementById('assessmentDetails').style.display = document.getElementById('assessmentCheckbox').checked ? 'block' : 'none';
});

// ========== CLASSES ==========
async function loadClasses() {
  const res = await fetch(`/api/classes?tenant=${tenant}`);
  const r = await res.json(); classes = r.data || r;
  renderClassesTable();
}
function renderClassesTable() {
  const tbody = document.querySelector('#classesTable tbody');
  tbody.innerHTML = '';
  if (!classes.length) { tbody.innerHTML = '<tr><td colspan="6" class="text-muted">No classes configured yet.</td></tr>'; return; }
  classes.forEach(c => {
    const row = document.createElement('tr');
    row.innerHTML = `<td>${c.name}</td><td>${c.numeric_order || '-'}</td><td>${c.section || '-'}</td><td>${c.capacity || '-'}</td><td>${c.class_teacher || '-'}</td>
      <td class="actions"><button class="btn-icon view-class" data-id="${c.id}">👥</button><button class="btn-icon edit-class" data-id="${c.id}">✏️</button><button class="btn-icon delete-class" data-id="${c.id}">🗑️</button></td>`;
    tbody.appendChild(row);
  });
  document.querySelectorAll('#classesTable .view-class').forEach(btn => btn.onclick = () => viewClassStudents(btn.dataset.id));
  document.querySelectorAll('#classesTable .edit-class').forEach(btn => btn.onclick = () => editClass(btn.dataset.id));
  document.querySelectorAll('#classesTable .delete-class').forEach(btn => btn.onclick = () => deleteClass(btn.dataset.id));
}
function showClassModal(title, classObj = null) {
  document.getElementById('classModalTitle').innerText = title;
  document.getElementById('classModal').style.display = 'block';
  if (classObj) {
    document.getElementById('classId').value = classObj.id;
    document.getElementById('classNameInput').value = classObj.name;
    document.getElementById('numericOrder').value = classObj.numeric_order || '';
    document.getElementById('sectionInput').value = classObj.section || '';
    document.getElementById('capacityInput').value = classObj.capacity || 40;
    document.getElementById('classTeacher').value = classObj.class_teacher || '';
  } else {
    document.getElementById('classForm').reset();
    document.getElementById('classId').value = '';
  }
}
function hideClassModal() { document.getElementById('classModal').style.display = 'none'; }
async function saveClassFixed(e) {
  e.preventDefault();
  const id = document.getElementById('classId').value;
  const data = {
    name: document.getElementById('classNameInput').value,
    numeric_order: parseInt(document.getElementById('numericOrder').value) || null,
    section: document.getElementById('sectionInput').value,
    capacity: parseInt(document.getElementById('capacityInput').value) || 40,
    class_teacher: document.getElementById('classTeacher').value
  };
  const url = id ? `/api/classes/${id}?tenant=${tenant}` : `/api/classes?tenant=${tenant}`;
  const method = id ? 'PUT' : 'POST';
  const res = await fetch(url, { method, headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
  if (res.ok) { hideClassModal(); loadClasses(); }
  else { const err = await res.json(); alert('Error: ' + (err.error || 'Could not save')); }
}
function editClass(id) { const c = classes.find(c => c.id === id); if (c) showClassModal('Edit Class', c); }
async function deleteClass(id) { if (!confirm('Delete?')) return; await fetch(`/api/classes/${id}?tenant=${tenant}`, { method: 'DELETE' }); loadClasses(); }
async function viewClassStudents(classId) {
  const res = await fetch(`/api/classes/${classId}/students?tenant=${tenant}`);
  if (!res.ok) { alert('Could not load students.'); return; }
  const { class: classInfo, students: classStudents } = await res.json();
  document.getElementById('classStudentsTitle').innerText = `Students in ${classInfo.name} ${classInfo.section ? '('+classInfo.section+')' : ''}`;
  document.getElementById('classTeacherName').innerText = classInfo.class_teacher || 'Not assigned';
  const tbody = document.querySelector('#classStudentsTable tbody');
  tbody.innerHTML = '';
  if (!classStudents.length) { tbody.innerHTML = '<tr><td colspan="4" class="text-muted">No students enrolled.</td></tr>'; return; }
  classStudents.forEach(s => {
    const row = document.createElement('tr');
    row.innerHTML = `<td>${s.admission_no}</td><td>${s.first_name} ${s.last_name}</td><td>${s.parent_name || '-'}</td><td>${s.phone || '-'}</td>`;
    tbody.appendChild(row);
  });
  document.getElementById('classStudentsModal').style.display = 'block';
}
document.getElementById('addClassBtn').addEventListener('click', () => showClassModal('Add New Class'));
document.getElementById('closeClassModalBtn').addEventListener('click', hideClassModal);
document.getElementById('cancelClassBtn').addEventListener('click', hideClassModal);
document.getElementById('classForm').addEventListener('submit', saveClassFixed);
document.getElementById('closeClassStudentsBtn').addEventListener('click', () => document.getElementById('classStudentsModal').style.display = 'none');

// ========== STAFF ==========
async function loadStaff() {
  const res = await fetch(`/api/staff?tenant=${tenant}`);
  const r = await res.json(); staff = r.data || r;
  renderStaffTable();
}
function renderStaffTable() {
  const tbody = document.querySelector('#staffTable tbody');
  tbody.innerHTML = '';
  if (!staff.length) { tbody.innerHTML = '<tr><td colspan="7" class="text-muted">No staff members found.</td></tr>'; return; }
  staff.forEach(s => {
    const row = document.createElement('tr');
    row.innerHTML = `<td>${s.first_name} ${s.last_name}</td><td>${s.role}</td><td>${s.department || '-'}</td><td>${s.phone || '-'}</td><td>${s.email || '-'}</td><td>${s.joining_date || '-'}</td>
      <td class="actions"><button class="btn-icon edit-staff" data-id="${s.id}">✏️</button><button class="btn-icon delete-staff" data-id="${s.id}">🗑️</button></td>`;
    tbody.appendChild(row);
  });
  document.querySelectorAll('#staffTable .edit-staff').forEach(btn => btn.onclick = () => editStaff(btn.dataset.id));
  document.querySelectorAll('#staffTable .delete-staff').forEach(btn => btn.onclick = () => deleteStaff(btn.dataset.id));
}
function showStaffModal(title, staffObj = null) {
  document.getElementById('staffModalTitle').innerText = title;
  document.getElementById('staffModal').style.display = 'block';
  if (staffObj) {
    document.getElementById('staffId').value = staffObj.id;
    document.getElementById('staffFirstName').value = staffObj.first_name;
    document.getElementById('staffLastName').value = staffObj.last_name;
    document.getElementById('staffRole').value = staffObj.role;
    document.getElementById('staffDepartment').value = staffObj.department || '';
    document.getElementById('staffPhone').value = staffObj.phone || '';
    document.getElementById('staffEmail').value = staffObj.email || '';
    document.getElementById('staffJoiningDate').value = staffObj.joining_date || '';
  } else {
    document.getElementById('staffForm').reset();
    document.getElementById('staffId').value = '';
  }
}
function hideStaffModal() { document.getElementById('staffModal').style.display = 'none'; }
async function saveStaff(e) {
  e.preventDefault();
  const id = document.getElementById('staffId').value;
  const data = {
    first_name: document.getElementById('staffFirstName').value,
    last_name: document.getElementById('staffLastName').value,
    role: document.getElementById('staffRole').value,
    department: document.getElementById('staffDepartment').value,
    phone: document.getElementById('staffPhone').value,
    email: document.getElementById('staffEmail').value,
    joining_date: document.getElementById('staffJoiningDate').value
  };
  const url = id ? `/api/staff/${id}?tenant=${tenant}` : `/api/staff?tenant=${tenant}`;
  const method = id ? 'PUT' : 'POST';
  const res = await fetch(url, { method, headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
  if (res.ok) { hideStaffModal(); loadStaff(); }
  else { const err = await res.json(); alert('Error: ' + (err.error || 'Could not save')); }
}
function editStaff(id) { const s = staff.find(s => s.id === id); if (s) showStaffModal('Edit Staff', s); }
async function deleteStaff(id) { if (!confirm('Delete?')) return; await fetch(`/api/staff/${id}?tenant=${tenant}`, { method: 'DELETE' }); loadStaff(); }
document.getElementById('addStaffBtn').addEventListener('click', () => showStaffModal('Add Staff'));
document.getElementById('closeStaffModalBtn').addEventListener('click', hideStaffModal);
document.getElementById('cancelStaffBtn').addEventListener('click', hideStaffModal);
document.getElementById('staffForm').addEventListener('submit', saveStaff);

// ========== COMMITTEES ==========
async function loadCommittees() {
  const res = await fetch(`/api/committees?tenant=${tenant}`);
  committees = await res.json();
  renderCommitteesTable();
}
function renderCommitteesTable() {
  const tbody = document.querySelector('#committeesTable tbody');
  tbody.innerHTML = '';
  if (!committees.length) { tbody.innerHTML = '<tr><td colspan="5" class="text-muted">No committees yet.</td></tr>'; return; }
  committees.forEach(c => {
    const members = c.members ? c.members.split(',').map(m => m.trim()).filter(Boolean) : [];
    const row = document.createElement('tr');
    row.innerHTML = `<td>${c.name}</td><td>${c.description || '-'}</td><td>${c.chairperson || '-'}</td><td>${members.length ? members.join(', ') : '-'}</td>
      <td class="actions"><button class="btn-icon members" data-id="${c.id}">👥</button><button class="btn-icon edit-comm" data-id="${c.id}">✏️</button><button class="btn-icon delete-comm" data-id="${c.id}">🗑️</button></td>`;
    tbody.appendChild(row);
  });
  document.querySelectorAll('#committeesTable .members').forEach(btn => btn.onclick = () => openMembersModal(btn.dataset.id));
  document.querySelectorAll('#committeesTable .edit-comm').forEach(btn => btn.onclick = () => editCommittee(btn.dataset.id));
  document.querySelectorAll('#committeesTable .delete-comm').forEach(btn => btn.onclick = () => deleteCommittee(btn.dataset.id));
}
function showCommitteeModal(title, committee = null) {
  document.getElementById('committeeModalTitle').innerText = title;
  document.getElementById('committeeModal').style.display = 'block';
  if (committee) {
    document.getElementById('committeeId').value = committee.id;
    document.getElementById('committeeName').value = committee.name;
    document.getElementById('committeeDescription').value = committee.description || '';
  } else {
    document.getElementById('committeeForm').reset();
    document.getElementById('committeeId').value = '';
  }
}
function hideCommitteeModal() { document.getElementById('committeeModal').style.display = 'none'; }
async function saveCommittee(e) {
  e.preventDefault();
  const id = document.getElementById('committeeId').value;
  const data = { name: document.getElementById('committeeName').value, description: document.getElementById('committeeDescription').value };
  const url = id ? `/api/committees/${id}?tenant=${tenant}` : `/api/committees?tenant=${tenant}`;
  const method = id ? 'PUT' : 'POST';
  const res = await fetch(url, { method, headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
  if (res.ok) { hideCommitteeModal(); loadCommittees(); }
  else { const err = await res.json(); alert('Error: ' + (err.error || 'Could not save')); }
}
function editCommittee(id) { const c = committees.find(c => c.id === id); if (c) showCommitteeModal('Edit Committee', c); }
async function deleteCommittee(id) { if (!confirm('Delete?')) return; await fetch(`/api/committees/${id}?tenant=${tenant}`, { method: 'DELETE' }); loadCommittees(); }
function openMembersModal(committeeId) {
  currentCommitteeId = committeeId;
  const c = committees.find(c => c.id === committeeId);
  if (!c) return;
  const members = c.members ? c.members.split(',').map(m => m.trim()).filter(Boolean) : [];
  renderMembersList(members);
  document.getElementById('membersModal').style.display = 'block';
}
function renderMembersList(members) {
  const list = document.getElementById('membersList');
  list.innerHTML = members.length ? '<ul>' + members.map(m => `<li>${m}</li>`).join('') + '</ul>' : '<p>No members yet.</p>';
}
function addMember() {
  const input = document.getElementById('newMemberName');
  const name = input.value.trim();
  if (!name) return;
  const committee = committees.find(c => c.id === currentCommitteeId);
  if (!committee) return;
  const members = committee.members ? committee.members.split(',').map(m => m.trim()).filter(Boolean) : [];
  if (members.includes(name)) { alert('Member already exists.'); return; }
  members.push(name);
  updateCommitteeMembers(currentCommitteeId, members.join(', '));
  input.value = '';
}
async function updateCommitteeMembers(committeeId, membersString) {
  const res = await fetch(`/api/committees/${committeeId}?tenant=${tenant}`, {
    method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ members: membersString })
  });
  if (res.ok) {
    const updated = await res.json();
    const index = committees.findIndex(c => c.id === committeeId);
    if (index !== -1) committees[index] = updated;
    renderCommitteesTable();
    renderMembersList(updated.members.split(',').map(m => m.trim()).filter(Boolean));
  } else { const err = await res.json(); alert('Error: ' + (err.error || 'Unknown error')); }
}
document.getElementById('addCommitteeBtn').addEventListener('click', () => showCommitteeModal('Add Committee'));
document.getElementById('closeCommitteeModalBtn').addEventListener('click', hideCommitteeModal);
document.getElementById('cancelCommitteeBtn').addEventListener('click', hideCommitteeModal);
document.getElementById('committeeForm').addEventListener('submit', saveCommittee);
document.getElementById('closeMembersModalBtn').addEventListener('click', () => document.getElementById('membersModal').style.display = 'none');
document.getElementById('closeMembersBtn').addEventListener('click', () => document.getElementById('membersModal').style.display = 'none');
document.getElementById('addMemberBtn').addEventListener('click', addMember);
document.getElementById('newMemberName').addEventListener('keypress', (e) => { if (e.key === 'Enter') { e.preventDefault(); addMember(); } });

// ========== MONITORING ==========
async function loadMonitoringData() {
  const res = await fetch(`/api/monitoring?tenant=${tenant}`);
  if (!res.ok) return;
  const data = await res.json();
  document.getElementById('monitoringCards').innerHTML = `
    <div class="monitoring-card"><h3>Total Students</h3><div class="value">${data.stats.totalStudents}</div></div>
    <div class="monitoring-card"><h3>Total Staff</h3><div class="value">${data.stats.totalStaff}</div></div>
    <div class="monitoring-card"><h3>Total Classes</h3><div class="value">${data.stats.totalClasses}</div></div>
    <div class="monitoring-card"><h3>Committees</h3><div class="value">${data.stats.totalCommittees}</div></div>
    <div class="monitoring-card"><h3>Fees Collected</h3><div class="value">${data.stats.totalFees}</div></div>`;
  const classTbody = document.querySelector('#classEnrollmentTable tbody');
  classTbody.innerHTML = '';
  (data.classStudentCounts || []).forEach(c => classTbody.innerHTML += `<tr><td>${c.className}</td><td>${c.students}</td></tr>`);
  const recentTbody = document.querySelector('#recentEnrollmentsTable tbody');
  recentTbody.innerHTML = '';
  (data.recentEnrollments || []).forEach(s => recentTbody.innerHTML += `<tr><td>${s.admission_no}</td><td>${s.first_name} ${s.last_name}</td><td>${s.enrollment_date || '-'}</td></tr>`);
}

// ========== TEACHER MONITORING ==========
async function loadTeacherMonitoring() {
  const res = await fetch(`/api/teacher-monitoring?tenant=${tenant}`);
  if (!res.ok) return;
  const data = await res.json();
  document.getElementById('teacherStatsCards').innerHTML = `
    <div class="monitoring-card"><h3>Total Teachers</h3><div class="value">${data.stats.totalTeachers}</div></div>
    <div class="monitoring-card"><h3>Students Taught</h3><div class="value">${data.stats.totalStudentsTaught}</div></div>
    <div class="monitoring-card"><h3>Avg Students/Teacher</h3><div class="value">${data.stats.avgStudentsPerTeacher}</div></div>`;
  const listDiv = document.getElementById('teacherList');
  listDiv.innerHTML = '';
  if (!data.teachers || data.teachers.length === 0) {
    listDiv.innerHTML = '<p class="text-muted">No teachers found. Add a staff member with role "Teacher".</p>';
    return;
  }
  data.teachers.forEach(teacher => {
    const card = document.createElement('div');
    card.className = 'teacher-card';
    card.innerHTML = `<h3>${teacher.name}</h3><p><strong>Phone:</strong> ${teacher.phone || '-'} | <strong>Email:</strong> ${teacher.email || '-'}</p>`;
    if (teacher.classes && teacher.classes.length) {
      const tbl = document.createElement('table');
      tbl.innerHTML = `<thead><tr><th>Class</th><th>Students</th></tr></thead><tbody>${teacher.classes.map(c => `<tr><td>${c.name}</td><td>${c.students}</td></tr>`).join('')}</tbody>`;
      card.appendChild(tbl);
    } else card.innerHTML += '<p>No classes assigned.</p>';
    listDiv.appendChild(card);
  });
}

// ========== ATTENDANCE ==========
async function initAttendancePage() {
  const today = new Date().toISOString().split('T')[0];
  document.getElementById('attendanceDate').value = today;
  const classRes = await fetch(`/api/classes?tenant=${tenant}`);
  const allClassesData = await classRes.json();
  const clsList = allClassesData.data || allClassesData;
  const select = document.getElementById('classFilter');
  select.innerHTML = '<option value="">All Classes</option>';
  clsList.forEach(c => {
    const label = c.name + (c.section ? ` ${c.section}` : '');
    select.innerHTML += `<option value='${JSON.stringify({ name: c.name, section: c.section || '' })}'>${label}</option>`;
  });
  loadAttendance();
}
async function loadAttendance() {
  const date = document.getElementById('attendanceDate').value;
  const filterVal = document.getElementById('classFilter').value;
  let className = '', section = '';
  if (filterVal) { const parsed = JSON.parse(filterVal); className = parsed.name; section = parsed.section; }
  const url = `/api/attendance?tenant=${tenant}&date=${date}&class=${encodeURIComponent(className)}&section=${encodeURIComponent(section)}`;
  const res = await fetch(url);
  if (!res.ok) return;
  const data = await res.json();
  const tbody = document.querySelector('#attendanceTable tbody');
  tbody.innerHTML = '';
  if (data.students.length === 0) {
    tbody.innerHTML = '<tr><td colspan="6" class="text-muted">No students found.</td></tr>';
    return;
  }
  data.students.forEach(s => {
    const row = document.createElement('tr');
    row.innerHTML = `<td>${s.admission_no}</td><td>${s.first_name} ${s.last_name}</td><td>${s.class}</td><td>${s.section || '-'}</td>
      <td><select class="attendance-status" data-student-id="${s.id}">
        <option value="Present" ${s.attendance.status === 'Present' ? 'selected' : ''}>Present</option>
        <option value="Absent" ${s.attendance.status === 'Absent' ? 'selected' : ''}>Absent</option>
        <option value="Late" ${s.attendance.status === 'Late' ? 'selected' : ''}>Late</option></select></td>
      <td><input type="text" class="attendance-remarks" data-student-id="${s.id}" value="${s.attendance.remarks || ''}" placeholder="Optional"></td>`;
    tbody.appendChild(row);
  });
}
document.getElementById('loadAttendanceBtn').addEventListener('click', loadAttendance);
document.getElementById('saveAttendanceBtn').addEventListener('click', async () => {
  const date = document.getElementById('attendanceDate').value;
  if (!date) return alert('Please select a date.');
  const rows = document.querySelectorAll('#attendanceTable tbody tr');
  const records = [];
  rows.forEach(row => {
    const statusSelect = row.querySelector('.attendance-status');
    const remarksInput = row.querySelector('.attendance-remarks');
    if (statusSelect) records.push({ student_id: statusSelect.dataset.studentId, status: statusSelect.value, remarks: remarksInput ? remarksInput.value : '' });
  });
  if (records.length === 0) return alert('No students to save.');
  const res = await fetch(`/api/attendance?tenant=${tenant}`, {
    method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ date, records })
  });
  if (res.ok) { alert('Attendance saved!'); loadAttendance(); }
  else { const err = await res.json(); alert('Error: ' + (err.error || 'Could not save')); }
});

// ========== ASSESSMENTS ==========
async function initAssessmentsPage() {
  const classRes = await fetch(`/api/classes?tenant=${tenant}`);
  const classesList = await classRes.json();
  const all = classesList.data || classesList;
  const select = document.getElementById('assessmentClass');
  select.innerHTML = '<option value="">Select class</option>';
  all.forEach(c => { select.innerHTML += `<option value="${c.name}">${c.name + (c.section ? ` ${c.section}` : '')}</option>`; });
  loadAssessments();
}
async function loadAssessments() {
  const res = await fetch(`/api/assessments?tenant=${tenant}`);
  assessments = await res.json();
  renderAssessmentsTable();
}
function renderAssessmentsTable() {
  const tbody = document.querySelector('#assessmentsTable tbody');
  tbody.innerHTML = '';
  if (!assessments.length) { tbody.innerHTML = '<tr><td colspan="7" class="text-muted">No assessments yet.</td></tr>'; return; }
  assessments.forEach(a => {
    const row = document.createElement('tr');
    row.innerHTML = `<td>${a.name}</td><td>${a.type}</td><td>${a.date || '-'}</td><td>${a.subject || '-'}</td><td>${a.class} ${a.section ? '('+a.section+')' : ''}</td><td>${a.max_score}</td>
      <td class="actions"><button class="btn-icon enter-marks" data-id="${a.id}">📝</button><button class="btn-icon edit-assessment" data-id="${a.id}">✏️</button><button class="btn-icon delete-assessment" data-id="${a.id}">🗑️</button></td>`;
    tbody.appendChild(row);
  });
  document.querySelectorAll('.enter-marks').forEach(btn => btn.onclick = () => openMarksModal(btn.dataset.id));
  document.querySelectorAll('.edit-assessment').forEach(btn => btn.onclick = () => editAssessment(btn.dataset.id));
  document.querySelectorAll('.delete-assessment').forEach(btn => btn.onclick = () => deleteAssessment(btn.dataset.id));
}
function showAssessmentModal(title, assessment = null) {
  document.getElementById('assessmentModalTitle').innerText = title;
  document.getElementById('assessmentModal').style.display = 'block';
  if (assessment) {
    document.getElementById('assessmentId').value = assessment.id;
    document.getElementById('assessmentName').value = assessment.name;
    document.getElementById('assessmentType').value = assessment.type;
    document.getElementById('assessmentDateInput').value = assessment.date || '';
    document.getElementById('assessmentSubjectInput').value = assessment.subject || '';
    document.getElementById('assessmentClass').value = assessment.class;
    document.getElementById('assessmentMaxScore').value = assessment.max_score;
  } else {
    document.getElementById('assessmentForm').reset();
    document.getElementById('assessmentId').value = '';
  }
}
function hideAssessmentModal() { document.getElementById('assessmentModal').style.display = 'none'; }
async function saveAssessment(e) {
  e.preventDefault();
  const id = document.getElementById('assessmentId').value;
  const data = {
    name: document.getElementById('assessmentName').value,
    type: document.getElementById('assessmentType').value,
    date: document.getElementById('assessmentDateInput').value,
    subject: document.getElementById('assessmentSubjectInput').value,
    class: document.getElementById('assessmentClass').value,
    max_score: parseFloat(document.getElementById('assessmentMaxScore').value) || 100
  };
  const url = id ? `/api/assessments/${id}?tenant=${tenant}` : `/api/assessments?tenant=${tenant}`;
  const method = id ? 'PUT' : 'POST';
  const res = await fetch(url, { method, headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
  if (res.ok) { hideAssessmentModal(); loadAssessments(); }
  else { const err = await res.json(); alert('Error: ' + (err.error || 'Could not save')); }
}
function editAssessment(id) { const a = assessments.find(a => a.id === id); if (a) showAssessmentModal('Edit Assessment', a); }
async function deleteAssessment(id) { if (!confirm('Delete?')) return; await fetch(`/api/assessments/${id}?tenant=${tenant}`, { method: 'DELETE' }); loadAssessments(); }
async function openMarksModal(assessmentId) {
  const res = await fetch(`/api/assessments/${assessmentId}/marks?tenant=${tenant}`);
  if (!res.ok) return alert('Could not load marks data');
  const { assessment, students } = await res.json();
  currentMarksAssessmentId = assessmentId;
  document.getElementById('marksModalTitle').innerText = `Marks for ${assessment.name} (Max: ${assessment.max_score})`;
  const tbody = document.querySelector('#marksTable tbody');
  tbody.innerHTML = '';
  students.forEach(s => {
    const row = document.createElement('tr');
    row.innerHTML = `<td>${s.admission_no}</td><td>${s.first_name} ${s.last_name}</td>
      <td><input type="number" class="marks-input" data-student-id="${s.id}" value="${s.mark.score}" max="${assessment.max_score}" step="any" placeholder="Score"></td>
      <td><input type="text" class="remarks-input" data-student-id="${s.id}" value="${s.mark.remarks || ''}" placeholder="Optional"></td>`;
    tbody.appendChild(row);
  });
  document.getElementById('marksModal').style.display = 'block';
}
document.getElementById('saveMarksBtn').addEventListener('click', async () => {
  const rows = document.querySelectorAll('#marksTable tbody tr');
  const records = [];
  rows.forEach(row => {
    const scoreInput = row.querySelector('.marks-input');
    const remarksInput = row.querySelector('.remarks-input');
    if (scoreInput) records.push({ student_id: scoreInput.dataset.studentId, score: scoreInput.value ? parseFloat(scoreInput.value) : null, remarks: remarksInput ? remarksInput.value : '' });
  });
  const res = await fetch(`/api/assessments/${currentMarksAssessmentId}/marks?tenant=${tenant}`, {
    method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ records })
  });
  if (res.ok) { alert('Marks saved!'); document.getElementById('marksModal').style.display = 'none'; loadAssessments(); }
  else { const err = await res.json(); alert('Error: ' + (err.error || 'Could not save')); }
});
document.getElementById('addAssessmentBtn').addEventListener('click', () => showAssessmentModal('Add New Assessment'));
document.getElementById('closeAssessmentModalBtn').addEventListener('click', hideAssessmentModal);
document.getElementById('cancelAssessmentBtn').addEventListener('click', hideAssessmentModal);
document.getElementById('assessmentForm').addEventListener('submit', saveAssessment);
document.getElementById('closeMarksModalBtn').addEventListener('click', () => document.getElementById('marksModal').style.display = 'none');

// ========== RESULTS ==========
async function initResultsPage() {
  const classRes = await fetch(`/api/classes?tenant=${tenant}`);
  const classesList = await classRes.json();
  const all = classesList.data || classesList;
  const select = document.getElementById('resultsClassFilter');
  select.innerHTML = '<option value="">Select Class</option>';
  all.forEach(c => { select.innerHTML += `<option value="${c.name}">${c.name + (c.section ? ` ${c.section}` : '')}</option>`; });
}
async function loadResults() {
  const className = document.getElementById('resultsClassFilter').value;
  if (!className) return alert('Please select a class.');
  const res = await fetch(`/api/results?tenant=${tenant}&class=${encodeURIComponent(className)}`);
  if (!res.ok) return alert('Error loading results.');
  const data = await res.json();
  const tbody = document.querySelector('#resultsTable tbody');
  tbody.innerHTML = '';
  if (!data.students.length) { tbody.innerHTML = '<tr><td colspan="5" class="text-muted">No students in this class.</td></tr>'; return; }
  data.students.forEach(s => {
    const row = document.createElement('tr');
    row.innerHTML = `<td>${s.admission_no}</td><td>${s.first_name} ${s.last_name}</td><td>${s.totalScore} / ${s.totalMax}</td><td>${s.average}%</td>
      <td><span class="clickable view-details" data-student-id="${s.id}">View</span></td>`;
    tbody.appendChild(row);
  });
  document.querySelectorAll('.view-details').forEach(el => el.addEventListener('click', () => showStudentMarks(el.dataset.studentId)));
}
async function showStudentMarks(studentId) {
  const res = await fetch(`/api/students/${studentId}/marks?tenant=${tenant}`);
  if (!res.ok) return alert('Could not load student marks.');
  const { student, marks } = await res.json();
  document.getElementById('studentMarksTitle').innerText = `Marks for ${student.first_name} ${student.last_name}`;
  const tbody = document.querySelector('#studentMarksTable tbody');
  tbody.innerHTML = '';
  marks.forEach(m => {
    const row = document.createElement('tr');
    row.innerHTML = `<td>${m.assessmentName}</td><td>${m.type}</td><td>${m.subject || '-'}</td><td>${m.score !== null ? m.score : '-'}</td><td>${m.maxScore}</td><td>${m.remarks || '-'}</td>`;
    tbody.appendChild(row);
  });
  document.getElementById('studentMarksModal').style.display = 'block';
}
document.getElementById('loadResultsBtn').addEventListener('click', loadResults);
document.getElementById('closeStudentMarksBtn').addEventListener('click', () => document.getElementById('studentMarksModal').style.display = 'none');

// ========== ACCOUNTS ==========
async function initAccountsPage() {
  const sumRes = await fetch(`/api/finance-summary?tenant=${tenant}`);
  const sum = await sumRes.json();
  document.getElementById('financeSummaryCards').innerHTML = `
    <div class="monitoring-card"><h3>Total Invoiced</h3><div class="value">K ${sum.totalInvoiced.toLocaleString()}</div></div>
    <div class="monitoring-card"><h3>Total Collected</h3><div class="value">K ${sum.totalCollected.toLocaleString()}</div></div>
    <div class="monitoring-card"><h3>Outstanding</h3><div class="value">K ${sum.outstanding.toLocaleString()}</div></div>
    <div class="monitoring-card"><h3>Invoices</h3><div class="value">${sum.invoiceCount}</div></div>`;
  await loadFeeTypes();
  await loadInvoices();
  const studentsRes = await fetch(`/api/enrollments?tenant=${tenant}`);
  const allStudents = await studentsRes.json();
  const studentList = allStudents.data || allStudents;
  const studentSelect = document.getElementById('invoiceStudent');
  studentSelect.innerHTML = '<option value="">Select Student</option>';
  studentList.forEach(s => { studentSelect.innerHTML += `<option value="${s.id}">${s.admission_no} - ${s.first_name} ${s.last_name}</option>`; });
  await populatePaymentInvoiceSelect();
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
      document.getElementById(btn.dataset.tab).classList.add('active');
      if (btn.dataset.tab === 'paymentsTab') populatePaymentInvoiceSelect();
    });
  });
}
async function loadFeeTypes() {
  const res = await fetch(`/api/fee-types?tenant=${tenant}`);
  feeTypes = await res.json();
  renderFeeTypesTable();
  const container = document.getElementById('feeTypeCheckboxes');
  container.innerHTML = feeTypes.map(ft => `<label class="checkbox-label"><input type="checkbox" value="${ft.id}"> ${ft.name} (K ${ft.default_amount || 0})</label><br>`).join('');
}
function renderFeeTypesTable() {
  const tbody = document.querySelector('#feeTypesTable tbody');
  tbody.innerHTML = '';
  feeTypes.forEach(ft => {
    const row = document.createElement('tr');
    row.innerHTML = `<td>${ft.name}</td><td>${ft.description || ''}</td><td>K ${ft.default_amount || 0}</td>
      <td class="actions"><button class="btn-icon edit-ft" data-id="${ft.id}">✏️</button><button class="btn-icon delete-ft" data-id="${ft.id}">🗑️</button></td>`;
    tbody.appendChild(row);
  });
  document.querySelectorAll('.edit-ft').forEach(btn => btn.addEventListener('click', () => editFeeType(btn.dataset.id)));
  document.querySelectorAll('.delete-ft').forEach(btn => btn.addEventListener('click', () => deleteFeeType(btn.dataset.id)));
}
function showFeeTypeModal(title, ft = null) {
  const name = prompt('Fee Type Name:', ft ? ft.name : '');
  if (!name) return;
  const description = prompt('Description:', ft ? ft.description : '');
  const amount = prompt('Default Amount:', ft ? ft.default_amount : '0');
  const data = { name, description, default_amount: parseFloat(amount) || 0 };
  const url = ft ? `/api/fee-types/${ft.id}?tenant=${tenant}` : `/api/fee-types?tenant=${tenant}`;
  const method = ft ? 'PUT' : 'POST';
  fetch(url, { method, headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) }).then(r => { if (r.ok) loadFeeTypes(); else alert('Error saving fee type'); });
}
function editFeeType(id) { const ft = feeTypes.find(f => f.id === id); if (ft) showFeeTypeModal('Edit Fee Type', ft); }
async function deleteFeeType(id) { if (confirm('Delete?')) { await fetch(`/api/fee-types/${id}?tenant=${tenant}`, { method: 'DELETE' }); loadFeeTypes(); } }
async function loadInvoices() {
  const res = await fetch(`/api/invoices?tenant=${tenant}`);
  invoices = await res.json();
  renderInvoicesTable();
}
function renderInvoicesTable() {
  const tbody = document.querySelector('#invoicesTable tbody');
  tbody.innerHTML = '';
  invoices.forEach(inv => {
    const student = inv.students || {};
    const row = document.createElement('tr');
    row.innerHTML = `
      <td>${inv.invoice_number}</td><td>${student.first_name || ''} ${student.last_name || ''} (${student.admission_no || ''})</td>
      <td>${inv.issue_date}</td><td>${inv.due_date || '-'}</td><td>K ${inv.total_amount.toLocaleString()}</td>
      <td><span class="status-badge status-${inv.status}">${inv.status}</span></td>
      <td class="actions"><button class="btn-icon view-inv" data-id="${inv.id}">🔍</button><button class="btn-icon pay-inv" data-id="${inv.id}">💵</button></td>`;
    tbody.appendChild(row);
  });
  document.querySelectorAll('.view-inv').forEach(btn => btn.addEventListener('click', () => viewInvoice(btn.dataset.id)));
  document.querySelectorAll('.pay-inv').forEach(btn => btn.addEventListener('click', () => quickPayInvoice(btn.dataset.id)));
}
async function generateInvoice(e) {
  e.preventDefault();
  const student_id = document.getElementById('invoiceStudent').value;
  const fee_type_ids = Array.from(document.querySelectorAll('#feeTypeCheckboxes input:checked')).map(cb => cb.value);
  const due_date = document.getElementById('invoiceDueDate').value;
  if (!student_id || fee_type_ids.length === 0) return alert('Select student and at least one fee type.');
  const res = await fetch(`/api/invoices/generate?tenant=${tenant}`, {
    method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ student_id, fee_type_ids, due_date })
  });
  if (res.ok) { document.getElementById('generateInvoiceModal').style.display = 'none'; loadInvoices(); initAccountsPage(); }
  else alert('Error generating invoice');
}
async function viewInvoice(id) {
  const res = await fetch(`/api/invoices/${id}?tenant=${tenant}`);
  const inv = await res.json();
  const student = inv.students || {};
  let html = `<p><strong>Invoice:</strong> ${inv.invoice_number}</p><p><strong>Student:</strong> ${student.first_name || ''} ${student.last_name || ''} (${student.admission_no || ''})</p><p><strong>Status:</strong> ${inv.status}</p><h4>Items</h4><ul>${inv.items.map(i => `<li>${i.description} - K ${i.amount.toLocaleString()}</li>`).join('')}</ul><h4>Payments</h4>`;
  if (inv.payments.length) html += inv.payments.map(p => `<p>${p.payment_date} - K ${p.amount.toLocaleString()} (${p.payment_method}) Receipt: ${p.receipt_number}</p>`).join('');
  else html += '<p>No payments yet.</p>';
  document.getElementById('invoiceDetailContent').innerHTML = html;
  document.getElementById('invoiceDetailModal').style.display = 'block';
}
function quickPayInvoice(invoiceId) {
  document.getElementById('paymentInvoiceSelect').value = invoiceId;
  document.querySelector('#paymentsTab').classList.add('active');
  document.querySelector('#invoicesTab').classList.remove('active');
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.querySelector('[data-tab="paymentsTab"]').classList.add('active');
}
async function populatePaymentInvoiceSelect() {
  const select = document.getElementById('paymentInvoiceSelect');
  const currentVal = select.value;
  const res = await fetch(`/api/invoices?tenant=${tenant}`);
  const invs = await res.json();
  select.innerHTML = '<option value="">-- Select --</option>';
  invs.forEach(inv => { const student = inv.students || {}; select.innerHTML += `<option value="${inv.id}">${inv.invoice_number} - ${student.first_name || ''} ${student.last_name || ''} (${inv.status})</option>`; });
  if (currentVal) select.value = currentVal;
}
async function recordPayment() {
  const invoice_id = document.getElementById('paymentInvoiceSelect').value;
  const amount = document.getElementById('paymentAmount').value;
  const payment_method = document.getElementById('paymentMethod').value;
  const remarks = document.getElementById('paymentRemarks').value;
  if (!invoice_id || !amount) return alert('Select invoice and enter amount.');
  const res = await fetch(`/api/payments?tenant=${tenant}`, {
    method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ invoice_id, amount: parseFloat(amount), payment_method, remarks })
  });
  if (res.ok) {
    const payment = await res.json();
    document.getElementById('receiptContent').innerHTML = `<h3>Receipt</h3><p><strong>Receipt No:</strong> ${payment.receipt_number}</p><p><strong>Amount:</strong> K ${parseFloat(payment.amount).toLocaleString()}</p><p><strong>Method:</strong> ${payment.payment_method}</p><p><strong>Date:</strong> ${payment.payment_date}</p>`;
    document.getElementById('receiptModal').style.display = 'block';
    loadInvoices(); initAccountsPage();
  } else alert('Error recording payment');
}
document.getElementById('addFeeTypeBtn').addEventListener('click', () => showFeeTypeModal('Add Fee Type'));
document.getElementById('generateInvoiceBtn').addEventListener('click', () => document.getElementById('generateInvoiceModal').style.display = 'block');
document.getElementById('closeGenerateInvoiceBtn').addEventListener('click', () => document.getElementById('generateInvoiceModal').style.display = 'none');
document.getElementById('cancelGenerateInvoice').addEventListener('click', () => document.getElementById('generateInvoiceModal').style.display = 'none');
document.getElementById('generateInvoiceForm').addEventListener('submit', generateInvoice);
document.getElementById('recordPaymentBtn').addEventListener('click', recordPayment);
document.getElementById('closeInvoiceDetailBtn').addEventListener('click', () => document.getElementById('invoiceDetailModal').style.display = 'none');
document.getElementById('closeReceiptBtn').addEventListener('click', () => document.getElementById('receiptModal').style.display = 'none');

// ========== NOTIFICATIONS ==========
async function loadNotifications() {
  const res = await fetch(`/api/notifications?tenant=${tenant}`);
  const data = await res.json();
  renderNotificationsTable(data);
}
function renderNotificationsTable(data) {
  const tbody = document.querySelector('#notificationsTable tbody');
  tbody.innerHTML = '';
  if (!data.length) { tbody.innerHTML = '<tr><td colspan="8" class="text-muted">No notifications yet.</td></tr>'; return; }
  data.forEach(n => {
    const labelsHtml = (n.labels || '').split(',').filter(l => l.trim()).map(l => `<span class="label-tag">${l.trim()}</span>`).join('') || '-';
    const row = document.createElement('tr');
    row.innerHTML = `<td>${n.title}</td><td>${n.type}</td>
      <td><span class="priority-badge priority-${n.priority || 'Medium'}">${n.priority || 'Medium'}</span></td>
      <td>${labelsHtml}</td><td>${n.message || '-'}</td><td>${n.target_audience || 'All'}</td>
      <td>${new Date(n.created_at).toLocaleDateString()}</td>
      <td class="actions"><button class="btn-icon edit-notification" data-id="${n.id}">✏️</button><button class="btn-icon delete-notification" data-id="${n.id}">🗑️</button></td>`;
    tbody.appendChild(row);
  });
  document.querySelectorAll('#notificationsTable .edit-notification').forEach(btn => btn.onclick = () => editNotification(btn.dataset.id, data));
  document.querySelectorAll('#notificationsTable .delete-notification').forEach(btn => btn.onclick = () => deleteNotification(btn.dataset.id));
}
function showNotificationModal(title, notification = null) {
  document.getElementById('notificationModalTitle').innerText = title;
  document.getElementById('notificationModal').style.display = 'block';
  if (notification) {
    document.getElementById('notificationId').value = notification.id;
    document.getElementById('notificationTitle').value = notification.title;
    document.getElementById('notificationType').value = notification.type;
    document.getElementById('notificationPriority').value = notification.priority || 'Medium';
    document.getElementById('notificationLabels').value = notification.labels || '';
    document.getElementById('notificationMessage').value = notification.message || '';
    document.getElementById('notificationAudience').value = notification.target_audience || '';
  } else {
    document.getElementById('notificationForm').reset();
    document.getElementById('notificationId').value = '';
    document.getElementById('notificationPriority').value = 'Medium';
  }
}
function hideNotificationModal() { document.getElementById('notificationModal').style.display = 'none'; }
async function saveNotification(e) {
  e.preventDefault();
  const id = document.getElementById('notificationId').value;
  const data = {
    title: document.getElementById('notificationTitle').value,
    message: document.getElementById('notificationMessage').value,
    type: document.getElementById('notificationType').value,
    target_audience: document.getElementById('notificationAudience').value,
    priority: document.getElementById('notificationPriority').value,
    labels: document.getElementById('notificationLabels').value
  };
  const url = id ? `/api/notifications/${id}?tenant=${tenant}` : `/api/notifications?tenant=${tenant}`;
  const method = id ? 'PUT' : 'POST';
  const res = await fetch(url, { method, headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
  if (res.ok) { hideNotificationModal(); loadNotifications(); }
  else { const err = await res.json(); alert('Error: ' + (err.error || 'Could not save')); }
}
function editNotification(id, list) { const n = list.find(n => n.id === id); if (n) showNotificationModal('Edit Notification', n); }
async function deleteNotification(id) { if (!confirm('Delete?')) return; await fetch(`/api/notifications/${id}?tenant=${tenant}`, { method: 'DELETE' }); loadNotifications(); }
document.getElementById('addNotificationBtn').addEventListener('click', () => showNotificationModal('Add Notification'));
document.getElementById('closeNotificationModalBtn').addEventListener('click', hideNotificationModal);
document.getElementById('cancelNotificationBtn').addEventListener('click', hideNotificationModal);
document.getElementById('notificationForm').addEventListener('submit', saveNotification);

// ========== SIDEBAR & MOBILE ==========
document.querySelectorAll('.nav-item[data-module]').forEach(item => {
  item.addEventListener('click', (e) => { e.preventDefault(); switchModule(item.dataset.module); });
});
document.getElementById('hamburgerBtn').addEventListener('click', () => {
  document.getElementById('sidebar').classList.add('open');
  document.getElementById('sidebarOverlay').classList.add('show');
});
document.getElementById('sidebarOverlay').addEventListener('click', () => {
  document.getElementById('sidebar').classList.remove('open');
  document.getElementById('sidebarOverlay').classList.remove('show');
});

// ========== INIT ==========
(async () => {
  await loadTenantInfo();
  // Hide payment features for non‑private schools
  if (tenantInfo.type !== 'private') {
    const payNav = document.querySelector('.nav-item[data-module="accounts"]');
    if (payNav) payNav.style.display = 'none';
    const feeModal = document.getElementById('feeModal');
    if (feeModal) feeModal.style.display = 'none';
  }
  switchModule('dashboard');
})();
</script>
</body>
</html>
